{
  "name": "nix-shell-action",
  "description": "Run any command you like in a deterministic Nix shell on Linux and macOS.",
  "version": "3.4.0",
  "author": "",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/actions/typescript-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workflow/nix-shell-action.git"
  },
  "bugs": {
    "url": "https://github.com/workflow/nix-shell-action/issues"
  },
  "keywords": [
    "actions",
    "nix",
    "ci",
    "dependency-management"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest --passWithNoTests",
    "coverage": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest --coverage",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "local-action": "npx local-action . src/main.ts .env",
    "package": "npx rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest --passWithNoTests",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.8",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.0.0",
    "@github/local-action": "^2.4.1",
    "@jest/globals": "^30.0.0",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.0",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-prettier": "^5.5.0",
    "jest": "^30.0.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.41.0",
    "ts-jest": "^29.4.0",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.33.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.41.0"
  }
}
